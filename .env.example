# Environment Variables for Nick Investments Website
# Copy this file to .env.local and fill in your values

# ===========================================
# CONTACT INFORMATION (Public - displayed on site)
# ===========================================
NEXT_PUBLIC_PHONE_NUMBER=+91XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
NEXT_PUBLIC_EMAIL=info@nickinvestments.com

# ===========================================
# API ROUTES & SERVICES
# ===========================================

# Email Service (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Admin email for lead notifications
ADMIN_EMAIL=admin@nickinvestments.com
FROM_EMAIL=noreply@nickinvestments.com

# ===========================================
# WHATSAPP INTEGRATION (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886
INDIA_WHATSAPP_NUMBER=+91XXXXXXXXXX

# ===========================================
# CRM INTEGRATION (Optional)
# ===========================================

# HubSpot
HUBSPOT_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Sheets (for lead tracking)
GOOGLE_SHEETS_ID=xxxxxxxxxxxxxxxxxxxx

# ===========================================
# SANITY CMS (https://sanity.io)
# ===========================================
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=skxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL=https://nickinvestments.com
NEXT_PUBLIC_SITE_NAME=Nick Investments
